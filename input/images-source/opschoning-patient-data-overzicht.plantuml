@startuml opschoning-patient-data-overzicht

skinparam activity {
  BackgroundColor #f5f5f5
  BorderColor #333333
}

|Koppeltaalvoorziening|
start
label start_termijn
:Bewaartermijn verstreken /\ncontractbeeindiging;
:Maak Task per opt-in doelapp\n(code=delete-pending,\nowner=Device, status=requested);
:AuditEvent (archive);
:Subscription-notificatie\nnaar doelapplicaties;

|Doelapplicaties|
:Grace period:\ndata veiligstellen;
if (Reactie?) then (noodrem)
  :Task status=on-hold\n(of rejected = permanent);
  :AuditEvent (hold);
  :...wacht op opheffing...;
  :Task status=accepted;
  :AuditEvent (unhold);
else (groen licht / geen actie)
  :Task status=accepted\n(of geen actie = opt-out);
endif

|Koppeltaalvoorziening|
if (Hernieuwde\nbetrokkenheid\ntijdens grace period?) then (ja)
  :Tasks status=cancelled;
  :AuditEvent (reactivate);
  :Bewaartermijn herstart;
  goto start_termijn
else (nee)
endif

|Koppeltaalvoorziening|
:Tasks status=completed;
:$purge operatie;
:AuditEvent (destroy);
note right
  AuditEvents (incl. destroy)
  overleven de $purge
end note

stop

@enduml
