@startuml opschoning-patient-data-interactie

participant "Koppeltaal-\nvoorziening" as KT
participant "Doelapplicatie A" as AppA
participant "Doelapplicatie B" as AppB

== Verwijdering aankondigen ==

KT -> KT : Bewaartermijn verstreken
KT -> AppA : POST Task\n(code=delete-pending,\nowner=Device A, status=requested)
KT -> AppB : POST Task\n(code=delete-pending,\nowner=Device B, status=requested)
KT -> KT : AuditEvent (archive)
note over AppA, AppB : Subscription:\nTask?code=delete-pending\n&status=requested

== Grace period ==

AppA -> KT : GET Patient resources\n(data veiligstellen)
AppA -> KT : PUT Task A\n(status=accepted)
note right of AppA : Groen licht

AppB -> KT : PUT Task B\n(status=on-hold, statusReason)
KT -> KT : AuditEvent (hold)
note right of AppB : Noodrem:\nproces pauzeert

...wacht op opheffing...

AppB -> KT : PUT Task B\n(status=accepted)
KT -> KT : AuditEvent (unhold)

== Activiteitscheck ==

KT -> KT : Grace verstreken, geen blokkade\nof alle Tasks accepted (fast-track)
KT -> KT : Check: hernieuwde\nbetrokkenheid?
note right of KT : Bij ja: Tasks cancelled,\nAuditEvent (reactivate),\nbewaartermijn herstart

== Definitieve verwijdering ==

KT -> KT : Tasks status=completed
KT -> KT : $purge (Patient + compartment,\nincl. de Tasks)
KT -> KT : AuditEvent (destroy)
note right of KT : destroy-AuditEvent overleeft\nde $purge -> post-delete signaal

@enduml
