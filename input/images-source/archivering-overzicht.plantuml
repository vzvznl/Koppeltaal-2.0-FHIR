@startuml archivering-overzicht

skinparam activity {
  BackgroundColor #f5f5f5
  BorderColor #333333
}

|Koppeltaalvoorziening|
start
label start_termijn
:Bewaartermijn verstreken /\ncontractbeeindiging;

|Koppeltaalvoorziening|
:Patient.meta.tag =\nDELETE_PENDING;
:AuditEvent\n(delete-initiated);
:Subscription notificatie\nnaar doelapplicaties;

|Doelapplicaties|
:Grace period:\ndata veiligstellen;

if (Noodrem?) then (ja)
  :DELETE_HOLD;
  :AuditEvent\n(delete-hold);
  :...wacht op opheffing...;
  :DELETE_HOLD\nopgeheven;
  :AuditEvent\n(delete-hold-released);
else (nee / time-out)
endif

|Koppeltaalvoorziening|
if (Hernieuwde\nbetrokkenheid\ntijdens grace period?) then (ja)
  :Tag DELETE_PENDING\nverwijderen;
  :AuditEvent\n(delete-aborted);
  :Bewaartermijn\nherstart;
  goto start_termijn
else (nee)
endif

|Koppeltaalvoorziening|
:$purge operatie;
:Patient.meta.tag =\nDELETED;
:AuditEvent\n(delete-completed);
note right
  AuditEvents overleven
  de $purge
end note

stop

@enduml
