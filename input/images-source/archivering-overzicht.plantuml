@startuml archivering-overzicht

skinparam activity {
  BackgroundColor #f5f5f5
  BorderColor #333333
}

|Initiator|
start
:Bewaartermijn verstreken /\ncontractbeeindiging;

|Koppeltaalvoorziening|
:Patient.meta.tag =\nARCHIVE_PENDING;
:AuditEvent\n(archive-initiated);
:Subscription notificatie\nnaar doelapplicaties;

|Doelapplicaties|
:Grace period:\ndata veiligstellen;

if (Noodrem?) then (ja)
  :ARCHIVE_HOLD;
  :AuditEvent\n(archive-hold);
  :...wacht op opheffing...;
  :ARCHIVE_HOLD\nopgeheven;
  :AuditEvent\n(archive-hold-released);
else (nee / time-out)
endif

|Koppeltaalvoorziening|
:Patient.meta.tag =\nARCHIVED;
:AuditEvent\n(archive-completed);
note right
  Data is read-only;
  niet in reguliere
  zoekresultaten
end note

|Initiator|
:Autorisatie definitieve\nverwijdering;

|Koppeltaalvoorziening|
:Patient.meta.tag =\nPURGE_PENDING;
:AuditEvent\n(purge-initiated);

:$purge operatie;
:AuditEvent\n(purge-completed);
note right
  AuditEvents overleven
  de $purge
end note

stop

@enduml
